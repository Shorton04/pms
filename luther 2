CLASS lcl_view IMPLEMENTATION.

  METHOD display_write.
    DATA: ls_final       TYPE ty_final,
          lv_exec_date   TYPE char10,
          lv_exec_time   TYPE char11.

    lv_exec_date = lcl_util=>format_date_mdy( sy-datum ).
    lv_exec_time = lcl_util=>format_time_12h( sy-uzeit ).

    WRITE: / text-h01.
    WRITE: / text-h02.
    WRITE: / 'Executed by:', sy-uname.
    WRITE: / 'Executed on:', lv_exec_date, lv_exec_time.
    SKIP.

    FORMAT COLOR COL_HEADING INTENSIFIED ON.
    WRITE: / text-c01,
             20 text-c02,
             35 text-c03,
             50 text-c04,
             68 text-c05,
             85 text-c06,
             105 text-c07,
             130 text-c08,
             165 text-c09.
    WRITE: / text-c10,
             40 text-c11,
             60 text-c12,
             80 text-c13,
             100 text-c14,
             115 text-c15.
    FORMAT RESET.

    LOOP AT lcl_model=>gt_final INTO ls_final.
      WRITE: / ls_final-material,
               20 ls_final-changed_on,
               35 ls_final-change_time,
               50 ls_final-changed_by,
               68 ls_final-tabname,
               85 ls_final-fname,
               105 ls_final-change_type,
               130 ls_final-old_contents,
               165 ls_final-new_contents.
      WRITE: / ls_final-table_key,
               40 ls_final-change_object,
               60 ls_final-object_value,
               80 ls_final-change_number,
               100 ls_final-tcode,
               115 ls_final-mat_desc.
      ULINE.
    ENDLOOP.
  ENDMETHOD.

  METHOD display_alv.
    DATA: lo_alv       TYPE REF TO cl_salv_table,
          lo_columns   TYPE REF TO cl_salv_columns_table,
          lo_column    TYPE REF TO cl_salv_column_table,
          lo_functions TYPE REF TO cl_salv_functions_list,
          lo_display   TYPE REF TO cl_salv_display_settings,
          lo_sorts     TYPE REF TO cl_salv_sorts,
          lo_events    TYPE REF TO cl_salv_events_table,
          lo_handler   TYPE REF TO lcl_event_handler,
          lo_header    TYPE REF TO cl_salv_form_layout_grid,
          lv_exec_date TYPE char10,
          lv_exec_time TYPE char11.

    lv_exec_date = lcl_util=>format_date_mdy( sy-datum ).
    lv_exec_time = lcl_util=>format_time_12h( sy-uzeit ).

