       ty_r_udate TYPE RANGE OF cdhdr-udate,
       ty_r_mtart TYPE RANGE OF mara-mtart.

TYPES: BEGIN OF ty_objid,
         objectid TYPE cdhdr-objectid,
       END OF ty_objid.
