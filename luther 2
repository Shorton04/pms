TYPES: BEGIN OF ty_final,
         material      TYPE mara-matnr,
         changed_on    TYPE char10,          " MM/DD/YYYY
         change_time   TYPE char11,          " HH:MM:SS AM/PM
         changed_by    TYPE cdhdr-username,
         tabname       TYPE cdpos-tabname,
         fname         TYPE cdpos-fname,
         change_type   TYPE char20,
         old_contents  TYPE cdpos-value_old,
         new_contents  TYPE cdpos-value_new,
         table_key     TYPE cdpos-tabkey,
         change_object TYPE cdpos-objectclas,
         object_value  TYPE cdpos-objectid,
         change_number TYPE cdpos-changenr,
         tcode         TYPE cdhdr-tcode,
         mat_desc      TYPE makt-maktx,
         sort_date     TYPE cdhdr-udate,     " technical sort column
         sort_time     TYPE cdhdr-utime,     " technical sort column
         cell_color    TYPE lvc_t_scol,
       END OF ty_final.
TYPES tt_final TYPE STANDARD TABLE OF ty_final WITH DEFAULT KEY.

