*---------------------------------------------------------------------*
* SELECTION-SCREEN EVENTS
*---------------------------------------------------------------------*
AT SELECTION-SCREEN.
  lcl_validator=>validate_reservation_input( s_rsnum[] ).
  lcl_validator=>validate_material_input( s_matnr[] ).
  lcl_validator=>validate_plant_input( p_werks ).

*---------------------------------------------------------------------*
* START-OF-SELECTION
*---------------------------------------------------------------------*
START-OF-SELECTION.
  DATA(lo_model) = NEW lcl_model( ).
  gt_final = lo_model->get_data(
    it_rsnum = s_rsnum[]
    it_matnr = s_matnr[]
    iv_werks = p_werks ).

  DATA(lo_view) = NEW lcl_view( gt_final ).

  IF p_write = abap_true.
    lo_view->display_write( ).
  ELSE.
    lo_view->display_alv(
      iv_hotspot = COND abap_bool(
                     WHEN p_hsp = abap_true THEN abap_true
                     ELSE abap_false ) ).
  ENDIF.