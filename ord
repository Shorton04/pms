*---------------------------------------------------------------------*
* VALIDATION CLASS
*---------------------------------------------------------------------*
CLASS lcl_validator IMPLEMENTATION.

  METHOD validate_reservation_input.
    DATA ls_rsnum LIKE LINE OF it_rsnum.

    LOOP AT it_rsnum INTO ls_rsnum
      WHERE sign = 'I'
        AND option = 'EQ'
        AND low IS NOT INITIAL.

      SELECT SINGLE rsnum
        FROM rkpf
        INTO @DATA(lv_rsnum)
        WHERE rsnum = @ls_rsnum-low.

      IF sy-subrc <> 0.
        MESSAGE text-e01 TYPE 'E'.
      ENDIF.
    ENDLOOP.
  ENDMETHOD.

  METHOD validate_material_input.
    DATA ls_matnr LIKE LINE OF it_matnr.

    LOOP AT it_matnr INTO ls_matnr
      WHERE sign = 'I'
        AND option = 'EQ'
        AND low IS NOT INITIAL.

      SELECT SINGLE matnr
        FROM mara
        INTO @DATA(lv_matnr)
        WHERE matnr = @ls_matnr-low.

      IF sy-subrc <> 0.
        MESSAGE text-e02 TYPE 'E'.
      ENDIF.
    ENDLOOP.
  ENDMETHOD.

  METHOD validate_plant_input.
    IF iv_werks IS INITIAL.
      RETURN.
    ENDIF.

    SELECT SINGLE werks
      FROM t001w
      INTO @DATA(lv_werks)
      WHERE werks = @iv_werks.

    IF sy-subrc <> 0.
      MESSAGE text-e03 TYPE 'E'.
    ENDIF.
  ENDMETHOD.

ENDCLASS.

*---------------------------------------------------------------------*
* MODEL CLASS
*---------------------------------------------------------------------*
CLASS lcl_model IMPLEMENTATION.

  METHOD get_data.
    DATA: lt_base  TYPE STANDARD TABLE OF ty_resb_base WITH EMPTY KEY,
          lt_makt  TYPE SORTED TABLE OF ty_makt  WITH UNIQUE KEY matnr,
          lt_t001w TYPE SORTED TABLE OF ty_t001w WITH UNIQUE KEY werks,
          lt_werks TYPE ty_t_werks,
          ls_final TYPE ty_final.

    IF iv_werks IS NOT INITIAL.
      lt_werks = VALUE #(
        ( sign = 'I'
          option = 'EQ'
          low = iv_werks ) ).
    ENDIF.

    IF lt_werks IS INITIAL.
      SELECT
        a~rsnum,
        a~werks,
        a~matnr,
        a~rspos,
        a~aufnr,
        a~bdart,
        a~bwart,
        a~saknr,
        a~lgort,
        a~charg,
        a~bdter,
        a~bdmng,
        a~meins,
        a~shkzg,
        a~enmng,
        a~enwrt,
        a~waers,
        a~erfmg,
        a~erfme
        FROM resb AS a
        INNER JOIN mara AS b
          ON b~matnr = a~matnr
        WHERE a~rsnum IN @it_rsnum
          AND a~matnr IN @it_matnr
        INTO TABLE @lt_base.
    ELSE.
      SELECT
        a~rsnum,
        a~werks,
        a~matnr,
        a~rspos,
        a~aufnr,
        a~bdart,
        a~bwart,
        a~saknr,
        a~lgort,
        a~charg,
        a~bdter,
        a~bdmng,
        a~meins,
        a~shkzg,
        a~enmng,
        a~enwrt,
        a~waers,
        a~erfmg,
        a~erfme
        FROM resb AS a
        INNER JOIN mara AS b
          ON b~matnr = a~matnr
        WHERE a~rsnum IN @it_rsnum
          AND a~matnr IN @it_matnr
          AND a~werks IN @lt_werks
        INTO TABLE @lt_base.
    ENDIF.

    IF lt_base IS INITIAL.
      MESSAGE text-e04 TYPE 'S' DISPLAY LIKE 'E'.
      LEAVE LIST-PROCESSING.
    ENDIF.

    SORT lt_base BY rsnum werks matnr rspos.

    SELECT matnr, maktx
      FROM makt
      FOR ALL ENTRIES IN @lt_base
      WHERE matnr = @lt_base-matnr
        AND spras = @sy-langu
      INTO TABLE @DATA(lt_makt_raw).

    IF sy-subrc = 0.
      lt_makt = CORRESPONDING #( lt_makt_raw ).
    ENDIF.

    SELECT werks, name1
      FROM t001w
      FOR ALL ENTRIES IN @lt_base
      WHERE werks = @lt_base-werks
      INTO TABLE @DATA(lt_t001w_raw).

    IF sy-subrc = 0.
      lt_t001w = CORRESPONDING #( lt_t001w_raw ).
    ENDIF.

    LOOP AT lt_base INTO DATA(ls_base).
      CLEAR ls_final.

      ls_final-reservation     = ls_base-rsnum.
      ls_final-material        = ls_base-matnr.
      ls_final-item_no         = ls_base-rspos.
      ls_final-order_no        = ls_base-aufnr.
      ls_final-reqt_type       = ls_base-bdart.
      ls_final-movement_type   = ls_base-bwart.
      ls_final-gl_account      = ls_base-saknr.
      ls_final-sloc            = ls_base-lgort.
      ls_final-batch           = ls_base-charg.
      ls_final-reqt_date       = ls_base-bdter.
      ls_final-reqt_qty        = ls_base-bdmng.
      ls_final-base_unit       = ls_base-meins.
      ls_final-debit_credit    = ls_base-shkzg.
      ls_final-withdraw_qty    = ls_base-enmng.
      ls_final-withdr_value    = ls_base-enwrt.
      ls_final-currency        = ls_base-waers.
      ls_final-quantity_in_une = ls_base-erfmg.
      ls_final-unit_of_entry   = ls_base-erfme.

      READ TABLE lt_t001w INTO DATA(ls_t001w)
        WITH KEY werks = ls_base-werks
        BINARY SEARCH.
      IF sy-subrc = 0.
        ls_final-plant = |{ ls_base-werks } - { ls_t001w-name1 }|.
      ELSE.
        ls_final-plant = ls_base-werks.
      ENDIF.

      READ TABLE lt_makt INTO DATA(ls_makt)
        WITH KEY matnr = ls_base-matnr
        BINARY SEARCH.
      IF sy-subrc = 0.
        ls_final-mat_description = ls_makt-maktx.
      ENDIF.

      IF ls_final-reqt_qty = 0.
        ls_final-cell_color = VALUE #(
          ( fname = 'REQT_QTY'
            color-col = col_negative
            color-int = 0
            color-inv = 0 ) ).
      ENDIF.

      APPEND ls_final TO rt_final.
    ENDLOOP.

  ENDMETHOD.

ENDCLASS.

*---------------------------------------------------------------------*
* EVENT HANDLER CLASS
*---------------------------------------------------------------------*
CLASS lcl_events IMPLEMENTATION.

  METHOD set_data.
    mt_final = it_final.
  ENDMETHOD.

  METHOD on_link_click.
    READ TABLE mt_final INTO DATA(ls_final) INDEX row.
    IF sy-subrc <> 0.
      RETURN.
    ENDIF.

    IF column = 'MATERIAL' AND ls_final-material IS NOT INITIAL.
      SET PARAMETER ID 'MAT' FIELD ls_final-material.
      CALL TRANSACTION 'MM03' WITH AUTHORITY-CHECK AND SKIP FIRST SCREEN.
    ENDIF.
  ENDMETHOD.

ENDCLASS.

