METHOD validate_reservation_input.
  DATA lv_rsnum TYPE rkpf-rsnum.
  FIELD-SYMBOLS <fs_rsnum> LIKE LINE OF it_rsnum.

  LOOP AT it_rsnum ASSIGNING <fs_rsnum>.

    CHECK <fs_rsnum>-sign = 'I'.

    CASE <fs_rsnum>-option.

      WHEN 'EQ'.
        IF <fs_rsnum>-low IS NOT INITIAL.
          SELECT SINGLE rsnum
            INTO @lv_rsnum
            FROM rkpf
            WHERE rsnum = @<fs_rsnum>-low.
          IF sy-subrc <> 0.
            MESSAGE text-e01 TYPE 'E'.
          ENDIF.
        ENDIF.

      WHEN 'BT'.
        IF <fs_rsnum>-low IS NOT INITIAL
           AND <fs_rsnum>-high IS NOT INITIAL.

          SELECT SINGLE rsnum
            INTO @lv_rsnum
            FROM rkpf
            WHERE rsnum BETWEEN @<fs_rsnum>-low AND @<fs_rsnum>-high.

          IF sy-subrc <> 0.
            MESSAGE text-e01 TYPE 'E'.
          ENDIF.
        ENDIF.

      WHEN 'CP' OR 'NP'.
        IF <fs_rsnum>-low IS NOT INITIAL.
          SELECT SINGLE rsnum
            INTO @lv_rsnum
            FROM rkpf
            WHERE rsnum LIKE @<fs_rsnum>-low.
          IF sy-subrc <> 0.
            MESSAGE text-e01 TYPE 'E'.
          ENDIF.
        ENDIF.

      WHEN OTHERS.
        IF <fs_rsnum>-low IS NOT INITIAL.
          SELECT SINGLE rsnum
            INTO @lv_rsnum
            FROM rkpf
            WHERE rsnum = @<fs_rsnum>-low.
          IF sy-subrc <> 0.
            MESSAGE text-e01 TYPE 'E'.
          ENDIF.
        ENDIF.

    ENDCASE.

  ENDLOOP.
ENDMETHOD.




