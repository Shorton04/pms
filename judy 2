            lo_column ?= lo_columns->get_column( 'REQ_DATE' ).
            lo_column->set_short_text(  CONV scrtext_s( TEXT-c12 ) ).
            lo_column->set_medium_text( CONV scrtext_m( TEXT-c12 ) ).
            lo_column->set_long_text(   CONV scrtext_l( TEXT-c12 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'REQ_QTY' ).
            lo_column->set_short_text(  CONV scrtext_s( TEXT-c13 ) ).
            lo_column->set_medium_text( CONV scrtext_m( TEXT-c13 ) ).
            lo_column->set_long_text(   CONV scrtext_l( TEXT-c13 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'BASE_UNIT' ).
            lo_column->set_short_text(  CONV scrtext_s( TEXT-c14 ) ).
            lo_column->set_medium_text( CONV scrtext_m( TEXT-c14 ) ).
            lo_column->set_long_text(   CONV scrtext_l( TEXT-c14 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'DEBIT_CREDIT' ).
            lo_column->set_short_text(  CONV scrtext_s( TEXT-c15 ) ).
            lo_column->set_medium_text( CONV scrtext_m( TEXT-c15 ) ).
            lo_column->set_long_text(   CONV scrtext_l( TEXT-c15 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'WITHDRAW_QTY' ).
            lo_column->set_short_text(  CONV scrtext_s( TEXT-c16 ) ).
            lo_column->set_medium_text( CONV scrtext_m( TEXT-c16 ) ).
            lo_column->set_long_text(   CONV scrtext_l( TEXT-c16 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'WITHDR_VALUE' ).
            lo_column->set_short_text(  CONV scrtext_s( TEXT-c17 ) ).
            lo_column->set_medium_text( CONV scrtext_m( TEXT-c17 ) ).
            lo_column->set_long_text(   CONV scrtext_l( TEXT-c17 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'CURRENCY' ).
            lo_column->set_short_text(  CONV scrtext_s( TEXT-c18 ) ).
            lo_column->set_medium_text( CONV scrtext_m( TEXT-c18 ) ).
            lo_column->set_long_text(   CONV scrtext_l( TEXT-c18 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'QTY_UNE' ).
            lo_column->set_short_text(  CONV scrtext_s( TEXT-c19 ) ).
            lo_column->set_medium_text( CONV scrtext_m( TEXT-c19 ) ).
            lo_column->set_long_text(   CONV scrtext_l( TEXT-c19 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'UNIT_ENTRY' ).
            lo_column->set_short_text(  CONV scrtext_s( TEXT-c20 ) ).
            lo_column->set_medium_text( CONV scrtext_m( TEXT-c20 ) ).
            lo_column->set_long_text(   CONV scrtext_l( TEXT-c20 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'PLANT_SORT' ).
            lo_column->set_technical( abap_true ).
          CATCH cx_salv_not_found.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'CELL_COLOR' ).
            lo_column->set_technical( abap_true ).
          CATCH cx_salv_not_found.
        ENDTRY.

        lo_functions = lo_alv->get_functions( ).
        lo_functions->set_all( abap_true ).

        lo_display = lo_alv->get_display_settings( ).
        lo_display->set_striped_pattern( abap_true ).
        lo_display->set_list_header( TEXT-h01 ).

        CREATE OBJECT lo_header.

        lo_header->create_label(
          row    = 1
          column = 1
          text   = TEXT-h01 ).

        lo_header->create_label(
          row    = 2
          column = 1
          text   = TEXT-h02 ).

        lo_header->create_label(
          row    = 3
          column = 1
          text   = |Executed by: { sy-uname }| ).

        lo_header->create_label(
          row    = 4
          column = 1
          text   = |Executed on: { lv_exec_date } { lv_exec_time }| ).

        lo_alv->set_top_of_list( lo_header ).

        lo_sorts = lo_alv->get_sorts( ).

        TRY.
            lo_sorts->add_sort(
              columnname = 'RESERVATION'
              sequence   = if_salv_c_sort=>sort_up ).
          CATCH cx_salv_not_found cx_salv_existing cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_sorts->add_sort(
              columnname = 'PLANT_SORT'
              sequence   = if_salv_c_sort=>sort_up
              subtotal   = abap_true ).
          CATCH cx_salv_not_found cx_salv_existing cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_sorts->add_sort(
              columnname = 'MATERIAL'
              sequence   = if_salv_c_sort=>sort_up ).
          CATCH cx_salv_not_found cx_salv_existing cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_sorts->add_sort(
              columnname = 'ITEM_NO'
              sequence   = if_salv_c_sort=>sort_up ).
          CATCH cx_salv_not_found cx_salv_existing cx_salv_data_error.
        ENDTRY.

        lo_events = lo_alv->get_event( ).
        CREATE OBJECT lo_handler.
        SET HANDLER lo_handler->on_link_click FOR lo_events.

        lo_alv->display( ).

      CATCH cx_salv_msg INTO DATA(lx_msg).
        MESSAGE lx_msg->get_text( ) TYPE 'I'.
    ENDTRY.
  ENDMETHOD.

ENDCLASS.

************************************************************************
* DATA
************************************************************************
DATA: go_model TYPE REF TO lcl_model,
      go_view  TYPE REF TO lcl_view.

************************************************************************
* VALIDATION
************************************************************************
AT SELECTION-SCREEN.
  lcl_model=>validate_reservation_input(
    it_rsnum = s_rsnum[] ).

  lcl_model=>validate_material_input(
    it_matnr = s_matnr[] ).

  lcl_model=>validate_plant_input(
    iv_werks = p_werks ).

************************************************************************
* MAIN PROCESS
************************************************************************
START-OF-SELECTION.
  CREATE OBJECT go_model.
  go_model->get_data(
    it_rsnum = s_rsnum[]
    it_matnr = s_matnr[]
    iv_werks = p_werks
    iv_hili  = COND abap_bool(
                 WHEN p_hili = 'X' THEN abap_true
                 ELSE abap_false ) ).

  CREATE OBJECT go_view.

  IF p_writ = 'X'.
    go_view->display_write( ).
  ELSE.
    go_view->display_alv( ).
  ENDIF.
