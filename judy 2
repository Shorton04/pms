************************************************************************
* HELPER CLASS IMPLEMENTATION
************************************************************************
CLASS lcl_util IMPLEMENTATION.

  METHOD format_date_mdy.
    CLEAR rv_text.
    IF iv_date IS INITIAL.
      RETURN.
    ENDIF.

    rv_text = |{ iv_date+4(2) }/{ iv_date+6(2) }/{ iv_date+0(4) }|.

    IF rv_text+0(1) = '0'.
      SHIFT rv_text LEFT BY 1 PLACES.
    ENDIF.

    IF rv_text+2(1) = '/' AND rv_text+3(1) = '0'.
      rv_text = |{ rv_text+0(3) }{ rv_text+4 }|.
    ELSEIF rv_text+1(1) = '/' AND rv_text+2(1) = '0'.
      rv_text = |{ rv_text+0(2) }{ rv_text+3 }|.
    ENDIF.
  ENDMETHOD.

  METHOD format_time_military.
    CLEAR rv_text.
    IF iv_time IS INITIAL.
      RETURN.
    ENDIF.

    rv_text = |{ iv_time+0(2) }:{ iv_time+2(2) }:{ iv_time+4(2) }|.
  ENDMETHOD.

ENDCLASS.

************************************************************************
* MODEL CLASS IMPLEMENTATION
************************************************************************
CLASS lcl_model IMPLEMENTATION.

  METHOD validate_reservation_input.
    DATA lv_rsnum TYPE rkpf-rsnum.
    FIELD-SYMBOLS <fs_rsnum> LIKE LINE OF it_rsnum.

    LOOP AT it_rsnum ASSIGNING <fs_rsnum>.

      CHECK <fs_rsnum>-sign = 'I'.

      CASE <fs_rsnum>-option.

        WHEN 'EQ'.
          IF <fs_rsnum>-low IS NOT INITIAL.
            SELECT SINGLE rsnum
              INTO @lv_rsnum
              FROM rkpf
              WHERE rsnum = @<fs_rsnum>-low.
            IF sy-subrc <> 0.
              MESSAGE TEXT-e01 TYPE 'E'.
            ENDIF.
          ENDIF.

        WHEN 'BT'.
          IF <fs_rsnum>-low IS NOT INITIAL
             AND <fs_rsnum>-high IS NOT INITIAL.

            SELECT SINGLE rsnum
              INTO @lv_rsnum
              FROM rkpf
              WHERE rsnum BETWEEN @<fs_rsnum>-low AND @<fs_rsnum>-high.

            IF sy-subrc <> 0.
              MESSAGE TEXT-e01 TYPE 'E'.
            ENDIF.
          ENDIF.

        WHEN 'CP' OR 'NP'.
          IF <fs_rsnum>-low IS NOT INITIAL.
            SELECT SINGLE rsnum
              INTO @lv_rsnum
              FROM rkpf
              WHERE rsnum = @<fs_rsnum>-low.
            IF sy-subrc <> 0.
              MESSAGE TEXT-e01 TYPE 'E'.
            ENDIF.
          ENDIF.

        WHEN OTHERS.
          IF <fs_rsnum>-low IS NOT INITIAL.
            SELECT SINGLE rsnum
              INTO @lv_rsnum
              FROM rkpf
              WHERE rsnum = @<fs_rsnum>-low.
            IF sy-subrc <> 0.
              MESSAGE TEXT-e01 TYPE 'E'.
            ENDIF.
          ENDIF.

      ENDCASE.

    ENDLOOP.
  ENDMETHOD.


  METHOD validate_material_input.
    DATA lv_matnr TYPE mara-matnr.
    FIELD-SYMBOLS <fs_matnr> LIKE LINE OF it_matnr.

    LOOP AT it_matnr ASSIGNING <fs_matnr>.

      CHECK <fs_matnr>-sign = 'I'.

      CASE <fs_matnr>-option.

        WHEN 'EQ'.
          IF <fs_matnr>-low IS NOT INITIAL.
            SELECT SINGLE matnr
              INTO @lv_matnr
              FROM mara
              WHERE matnr = @<fs_matnr>-low.
            IF sy-subrc <> 0.
              MESSAGE TEXT-e02 TYPE 'E'.
            ENDIF.
          ENDIF.

        WHEN 'BT'.
          IF <fs_matnr>-low IS NOT INITIAL
             AND <fs_matnr>-high IS NOT INITIAL.

            SELECT SINGLE matnr
              INTO @lv_matnr
              FROM mara
              WHERE matnr BETWEEN @<fs_matnr>-low AND @<fs_matnr>-high.

            IF sy-subrc <> 0.
              MESSAGE TEXT-e02 TYPE 'E'.
            ENDIF.
          ENDIF.

        WHEN 'CP'.
          IF <fs_matnr>-low IS NOT INITIAL.
            SELECT SINGLE matnr
              INTO @lv_matnr
              FROM mara
              WHERE matnr LIKE @<fs_matnr>-low.
            IF sy-subrc <> 0.
              MESSAGE TEXT-e02 TYPE 'E'.
            ENDIF.
          ENDIF.

        WHEN OTHERS.
          IF <fs_matnr>-low IS NOT INITIAL.
            SELECT SINGLE matnr
              INTO @lv_matnr
              FROM mara
              WHERE matnr = @<fs_matnr>-low.
            IF sy-subrc <> 0.
              MESSAGE TEXT-e02 TYPE 'E'.
            ENDIF.
          ENDIF.

      ENDCASE.

    ENDLOOP.
  ENDMETHOD.

  METHOD validate_plant_input.
    DATA lv_werks TYPE t001w-werks.

    IF iv_werks IS INITIAL.
      RETURN.
    ENDIF.

    SELECT SINGLE werks
      INTO @lv_werks
      FROM t001w
      WHERE werks = @iv_werks.

    IF sy-subrc <> 0.
      MESSAGE TEXT-e03 TYPE 'E'.
    ENDIF.
  ENDMETHOD.

  METHOD get_data.
    DATA lt_werks_rng TYPE rseloption.

    CLEAR: gt_raw, gt_makt, gt_t001w, gt_final.

    IF iv_werks IS NOT INITIAL.
      APPEND VALUE rsdsselopt(
        sign   = 'I'
        option = 'EQ'
        low    = iv_werks ) TO lt_werks_rng.
    ENDIF.

    IF iv_werks IS INITIAL.
      SELECT a~rsnum,
             a~werks,
             a~matnr,
             a~rspos,
             a~aufnr,
             a~bdart,
             a~bwart,
             a~saknr,
             a~lgort,
             a~charg,
             a~bdter,
             a~bdmng,
             a~meins,
             a~shkzg,
             a~enmng,
             a~enwrt,
             a~waers,
             a~erfmg,
             a~erfme
        INTO TABLE @gt_raw
        FROM resb AS a
        INNER JOIN mara AS b
          ON a~matnr = b~matnr
        WHERE a~rsnum IN @it_rsnum
          AND a~matnr IN @it_matnr.
    ELSE.
      SELECT a~rsnum,
             a~werks,
             a~matnr,
             a~rspos,
             a~aufnr,
             a~bdart,
             a~bwart,
             a~saknr,
             a~lgort,
             a~charg,
             a~bdter,
             a~bdmng,
             a~meins,
             a~shkzg,
             a~enmng,
             a~enwrt,
             a~waers,
             a~erfmg,
             a~erfme
        INTO TABLE @gt_raw
        FROM resb AS a
        INNER JOIN mara AS b
          ON a~matnr = b~matnr
        WHERE a~rsnum IN @it_rsnum
          AND a~matnr IN @it_matnr
          AND a~werks IN @lt_werks_rng.
    ENDIF.

    SORT gt_raw BY rsnum werks matnr rspos.

    IF gt_raw IS INITIAL.
      MESSAGE TEXT-e04 TYPE 'S' DISPLAY LIKE 'E'.
      LEAVE LIST-PROCESSING.
    ENDIF.

    SELECT matnr,
           maktx
      INTO TABLE @gt_makt
      FROM makt
      FOR ALL ENTRIES IN @gt_raw
      WHERE matnr = @gt_raw-matnr
        AND spras = @sy-langu.

    SORT gt_makt BY matnr.

    SELECT werks,
           name1
      INTO TABLE @gt_t001w
      FROM t001w
      FOR ALL ENTRIES IN @gt_raw
      WHERE werks = @gt_raw-werks.

    SORT gt_t001w BY werks.

    build_final_output( iv_hili = iv_hili ).

    IF gt_final IS INITIAL.
      MESSAGE TEXT-e04 TYPE 'S' DISPLAY LIKE 'E'.
      LEAVE LIST-PROCESSING.
    ENDIF.
  ENDMETHOD.

  METHOD build_final_output.
    DATA: ls_raw   TYPE ty_raw,
          ls_makt  TYPE ty_makt,
          ls_t001w TYPE ty_t001w,
          ls_final TYPE ty_final,
          ls_scol  TYPE lvc_s_scol.

    LOOP AT gt_raw INTO ls_raw.
      CLEAR: ls_makt, ls_t001w, ls_final.

      READ TABLE gt_makt INTO ls_makt
        WITH KEY matnr = ls_raw-matnr
        BINARY SEARCH.

      READ TABLE gt_t001w INTO ls_t001w
        WITH KEY werks = ls_raw-werks
        BINARY SEARCH.

      ls_final-reservation  = ls_raw-rsnum.

      IF ls_t001w-name1 IS INITIAL.
        ls_final-plant = ls_raw-werks.
      ELSE.
        ls_final-plant = |{ ls_raw-werks } - { ls_t001w-name1 }|.
      ENDIF.

      ls_final-material      = ls_raw-matnr.
      ls_final-mat_desc      = ls_makt-maktx.
      ls_final-item_no       = ls_raw-rspos.
      ls_final-order_no      = ls_raw-aufnr.
      ls_final-req_type      = ls_raw-bdart.
      ls_final-mov_type      = ls_raw-bwart.
      ls_final-gl_account    = ls_raw-saknr.
      ls_final-sloc          = ls_raw-lgort.
      ls_final-batch         = ls_raw-charg.
      ls_final-req_date      = lcl_util=>format_date_mdy( ls_raw-bdter ).
      ls_final-req_qty       = ls_raw-bdmng.
      ls_final-base_unit     = ls_raw-meins.
      ls_final-debit_credit  = ls_raw-shkzg.
      ls_final-withdraw_qty  = ls_raw-enmng.
      ls_final-withdr_value  = ls_raw-enwrt.
      ls_final-currency      = ls_raw-waers.
      ls_final-qty_une       = ls_raw-erfmg.
      ls_final-unit_entry    = ls_raw-erfme.
      ls_final-plant_sort    = ls_raw-werks.

      IF ls_raw-bdmng = 0.
        CLEAR ls_scol.
        ls_scol-fname = 'REQ_QTY'.
        ls_scol-color-col = 6.
        ls_scol-color-int = 1.
        ls_scol-color-inv = 0.
        APPEND ls_scol TO ls_final-cell_color.
      ENDIF.

      APPEND ls_final TO gt_final.
    ENDLOOP.

    SORT gt_final BY reservation ASCENDING
                     plant_sort ASCENDING
                     material ASCENDING
                     item_no ASCENDING.
  ENDMETHOD.

ENDCLASS.

************************************************************************
* EVENT HANDLER IMPLEMENTATION
************************************************************************
CLASS lcl_event_handler IMPLEMENTATION.
  METHOD on_link_click.
    READ TABLE lcl_model=>gt_final INTO DATA(ls_final) INDEX row.
    IF sy-subrc <> 0.
      RETURN.
    ENDIF.

    IF column = 'MATERIAL' AND p_hili = 'X'.
      SET PARAMETER ID 'MAT' FIELD ls_final-material.
      CALL TRANSACTION 'MM03' WITH AUTHORITY-CHECK AND SKIP FIRST SCREEN.
    ENDIF.
  ENDMETHOD.
ENDCLASS.

************************************************************************
* VIEW CLASS IMPLEMENTATION
************************************************************************
CLASS lcl_view IMPLEMENTATION.

  METHOD display_write.
    DATA: ls_final     TYPE ty_final,
          lv_exec_date TYPE char10,
          lv_exec_time TYPE char8.

    lv_exec_date = lcl_util=>format_date_mdy( sy-datum ).
    lv_exec_time = lcl_util=>format_time_military( sy-uzeit ).

    WRITE: / TEXT-h01.
    WRITE: / TEXT-h02.
    WRITE: / 'Executed by:', sy-uname.
    WRITE: / 'Executed on:', lv_exec_date, lv_exec_time.
    SKIP.

    FORMAT COLOR COL_HEADING INTENSIFIED ON.
    WRITE: / TEXT-c01, 15 TEXT-c02, 55 TEXT-c03, 75 TEXT-c04, 100 TEXT-c05.
    WRITE: / TEXT-c06, 15 TEXT-c07, 35 TEXT-c08, 55 TEXT-c09, 75 TEXT-c10.
    WRITE: / TEXT-c11, 15 TEXT-c12, 35 TEXT-c13, 55 TEXT-c14, 75 TEXT-c15.
    WRITE: / TEXT-c16, 20 TEXT-c17, 40 TEXT-c18, 55 TEXT-c19, 75 TEXT-c20.
    FORMAT RESET.

    LOOP AT lcl_model=>gt_final INTO ls_final.
      WRITE: / ls_final-reservation,
               15 ls_final-plant,
               55 ls_final-material,
               75 ls_final-mat_desc,
               100 ls_final-item_no.
      WRITE: / ls_final-order_no,
               15 ls_final-req_type,
               35 ls_final-mov_type,
               55 ls_final-gl_account,
               75 ls_final-sloc.
      WRITE: / ls_final-batch,
               15 ls_final-req_date,
               35 ls_final-req_qty,
               55 ls_final-base_unit,
               75 ls_final-debit_credit.
      WRITE: / ls_final-withdraw_qty,
               20 ls_final-withdr_value,
               40 ls_final-currency,
               55 ls_final-qty_une,
               75 ls_final-unit_entry.
      ULINE.
    ENDLOOP.
  ENDMETHOD.

  METHOD display_alv.
    DATA: lo_alv       TYPE REF TO cl_salv_table,
          lo_columns   TYPE REF TO cl_salv_columns_table,
          lo_column    TYPE REF TO cl_salv_column_table,
          lo_functions TYPE REF TO cl_salv_functions_list,
          lo_display   TYPE REF TO cl_salv_display_settings,
          lo_sorts     TYPE REF TO cl_salv_sorts,
          lo_header    TYPE REF TO cl_salv_form_layout_grid,
          lo_events    TYPE REF TO cl_salv_events_table,
          lo_handler   TYPE REF TO lcl_event_handler,
          lv_exec_date TYPE char10,
          lv_exec_time TYPE char8.

    lv_exec_date = lcl_util=>format_date_mdy( sy-datum ).
    lv_exec_time = lcl_util=>format_time_military( sy-uzeit ).

    TRY.
        cl_salv_table=>factory(
          IMPORTING
            r_salv_table = lo_alv
          CHANGING
            t_table      = lcl_model=>gt_final ).

        lo_columns = lo_alv->get_columns( ).

        TRY.
            lo_columns->set_optimize( ).
          CATCH cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_columns->set_color_column( 'CELL_COLOR' ).
          CATCH cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'RESERVATION' ).
            lo_column->set_short_text(  CONV scrtext_s( TEXT-c01 ) ).
            lo_column->set_medium_text( CONV scrtext_m( TEXT-c01 ) ).
            lo_column->set_long_text(   CONV scrtext_l( TEXT-c01 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'PLANT' ).
            lo_column->set_short_text(  CONV scrtext_s( TEXT-c02 ) ).
            lo_column->set_medium_text( CONV scrtext_m( TEXT-c02 ) ).
            lo_column->set_long_text(   CONV scrtext_l( TEXT-c02 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'MATERIAL' ).
            lo_column->set_short_text(  CONV scrtext_s( TEXT-c03 ) ).
            lo_column->set_medium_text( CONV scrtext_m( TEXT-c03 ) ).
            lo_column->set_long_text(   CONV scrtext_l( TEXT-c03 ) ).
            IF p_hili = 'X'.
              lo_column->set_cell_type( if_salv_c_cell_type=>hotspot ).
            ENDIF.
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
