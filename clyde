************************************************************************
* HELPER CLASS IMPLEMENTATION
************************************************************************
CLASS lcl_format_helper IMPLEMENTATION.

  METHOD format_date_mdy.
    CLEAR rv_text.
    IF iv_date IS INITIAL.
      RETURN.
    ENDIF.

    rv_text = |{ iv_date+4(2) }/{ iv_date+6(2) }/{ iv_date+0(4) }|.

    IF rv_text+0(1) = '0'.
      SHIFT rv_text LEFT BY 1 PLACES.
    ENDIF.

    IF rv_text+2(1) = '/' AND rv_text+3(1) = '0'.
      rv_text = |{ rv_text+0(3) }{ rv_text+4 }|.
    ELSEIF rv_text+1(1) = '/' AND rv_text+2(1) = '0'.
      rv_text = |{ rv_text+0(2) }{ rv_text+3 }|.
    ENDIF.
  ENDMETHOD.

  METHOD format_time_military.
    CLEAR rv_text.
    IF iv_time IS INITIAL.
      RETURN.
    ENDIF.

    rv_text = |{ iv_time+0(2) }:{ iv_time+2(2) }:{ iv_time+4(2) }|.
  ENDMETHOD.

ENDCLASS.

************************************************************************
* SERVICE CLASS IMPLEMENTATION
************************************************************************
CLASS lcl_reservation_service IMPLEMENTATION.

  METHOD validate_reservation_input.
    DATA lv_reservation TYPE rkpf-rsnum.
    FIELD-SYMBOLS <fs_reservation> LIKE LINE OF it_reservation.

    LOOP AT it_reservation ASSIGNING <fs_reservation>.

      CHECK <fs_reservation>-sign = 'I'.

      CASE <fs_reservation>-option.

        WHEN 'EQ'.
          IF <fs_reservation>-low IS NOT INITIAL.
            SELECT SINGLE rsnum
              INTO @lv_reservation
              FROM rkpf
              WHERE rsnum = @<fs_reservation>-low.
            IF sy-subrc <> 0.
              MESSAGE text-e01 TYPE 'E'.
            ENDIF.
          ENDIF.

        WHEN 'BT'.
          IF <fs_reservation>-low IS NOT INITIAL
             AND <fs_reservation>-high IS NOT INITIAL.

            SELECT SINGLE rsnum
              INTO @lv_reservation
              FROM rkpf
              WHERE rsnum BETWEEN @<fs_reservation>-low AND @<fs_reservation>-high.

            IF sy-subrc <> 0.
              MESSAGE text-e01 TYPE 'E'.
            ENDIF.
          ENDIF.

        WHEN 'CP' OR 'NP'.
          IF <fs_reservation>-low IS NOT INITIAL.
            SELECT SINGLE rsnum
              INTO @lv_reservation
              FROM rkpf
              WHERE rsnum = @<fs_reservation>-low.
            IF sy-subrc <> 0.
              MESSAGE text-e01 TYPE 'E'.
            ENDIF.
          ENDIF.

        WHEN OTHERS.
          IF <fs_reservation>-low IS NOT INITIAL.
            SELECT SINGLE rsnum
              INTO @lv_reservation
              FROM rkpf
              WHERE rsnum = @<fs_reservation>-low.
            IF sy-subrc <> 0.
              MESSAGE text-e01 TYPE 'E'.
            ENDIF.
          ENDIF.

      ENDCASE.

    ENDLOOP.
  ENDMETHOD.

  METHOD validate_material_input.
    DATA lv_material TYPE mara-matnr.
    FIELD-SYMBOLS <fs_material> LIKE LINE OF it_material.

    LOOP AT it_material ASSIGNING <fs_material>.

      CHECK <fs_material>-sign = 'I'.

      CASE <fs_material>-option.

        WHEN 'EQ'.
          IF <fs_material>-low IS NOT INITIAL.
            SELECT SINGLE matnr
              INTO @lv_material
              FROM mara
              WHERE matnr = @<fs_material>-low.
            IF sy-subrc <> 0.
              MESSAGE text-e02 TYPE 'E'.
            ENDIF.
          ENDIF.

        WHEN 'BT'.
          IF <fs_material>-low IS NOT INITIAL
             AND <fs_material>-high IS NOT INITIAL.

            SELECT SINGLE matnr
              INTO @lv_material
              FROM mara
              WHERE matnr BETWEEN @<fs_material>-low AND @<fs_material>-high.

            IF sy-subrc <> 0.
              MESSAGE text-e02 TYPE 'E'.
            ENDIF.
          ENDIF.

        WHEN 'CP'.
          IF <fs_material>-low IS NOT INITIAL.
            SELECT SINGLE matnr
              INTO @lv_material
              FROM mara
              WHERE matnr LIKE @<fs_material>-low.
            IF sy-subrc <> 0.
              MESSAGE text-e02 TYPE 'E'.
            ENDIF.
          ENDIF.

        WHEN OTHERS.
          IF <fs_material>-low IS NOT INITIAL.
            SELECT SINGLE matnr
              INTO @lv_material
              FROM mara
              WHERE matnr = @<fs_material>-low.
            IF sy-subrc <> 0.
              MESSAGE text-e02 TYPE 'E'.
            ENDIF.
          ENDIF.

      ENDCASE.

    ENDLOOP.
  ENDMETHOD.

  METHOD validate_plant_input.
    DATA lv_plant TYPE t001w-werks.

    IF iv_plant IS INITIAL.
      RETURN.
    ENDIF.

    SELECT SINGLE werks
      INTO @lv_plant
      FROM t001w
      WHERE werks = @iv_plant.

    IF sy-subrc <> 0.
      MESSAGE text-e03 TYPE 'E'.
    ENDIF.
  ENDMETHOD.

  METHOD get_data.
    DATA lt_plant_range TYPE rseloption.

    CLEAR: gt_reservation_data,
           gt_material_text,
           gt_plant_text,
           gt_report_output.

    IF iv_plant IS NOT INITIAL.
      APPEND VALUE rsdsselopt(
        sign   = 'I'
        option = 'EQ'
        low    = iv_plant ) TO lt_plant_range.
    ENDIF.

    IF iv_plant IS INITIAL.
      SELECT a~rsnum,
             a~werks,
             a~matnr,
             a~rspos,
             a~aufnr,
             a~bdart,
             a~bwart,
             a~saknr,
             a~lgort,
             a~charg,
             a~bdter,
             a~bdmng,
             a~meins,
             a~shkzg,
             a~enmng,
             a~enwrt,
             a~waers,
             a~erfmg,
             a~erfme
        INTO TABLE @gt_reservation_data
        FROM resb AS a
        INNER JOIN mara AS b
          ON a~matnr = b~matnr
        WHERE a~rsnum IN @it_reservation
          AND a~matnr IN @it_material.
    ELSE.
      SELECT a~rsnum,
             a~werks,
             a~matnr,
             a~rspos,
             a~aufnr,
             a~bdart,
             a~bwart,
             a~saknr,
             a~lgort,
             a~charg,
             a~bdter,
             a~bdmng,
             a~meins,
             a~shkzg,
             a~enmng,
             a~enwrt,
             a~waers,
             a~erfmg,
             a~erfme
        INTO TABLE @gt_reservation_data
        FROM resb AS a
        INNER JOIN mara AS b
          ON a~matnr = b~matnr
        WHERE a~rsnum IN @it_reservation
          AND a~matnr IN @it_material
          AND a~werks IN @lt_plant_range.
    ENDIF.

    SORT gt_reservation_data BY rsnum werks matnr rspos.

    IF gt_reservation_data IS INITIAL.
      MESSAGE text-e04 TYPE 'S' DISPLAY LIKE 'E'.
      LEAVE LIST-PROCESSING.
    ENDIF.

    SELECT matnr,
           maktx
      INTO TABLE @gt_material_text
      FROM makt
      FOR ALL ENTRIES IN @gt_reservation_data
      WHERE matnr = @gt_reservation_data-matnr
        AND spras = @sy-langu.

    SORT gt_material_text BY matnr.

    SELECT werks,
           name1
      INTO TABLE @gt_plant_text
      FROM t001w
      FOR ALL ENTRIES IN @gt_reservation_data
      WHERE werks = @gt_reservation_data-werks.

    SORT gt_plant_text BY werks.

    build_final_output( iv_highlight = iv_highlight ).

    IF gt_report_output IS INITIAL.
      MESSAGE text-e04 TYPE 'S' DISPLAY LIKE 'E'.
      LEAVE LIST-PROCESSING.
    ENDIF.
  ENDMETHOD.

  METHOD build_final_output.
    DATA: ls_reservation_data TYPE ty_reservation_data,
          ls_material_text    TYPE ty_material_text,
          ls_plant_text       TYPE ty_plant_text,
          ls_report_output    TYPE ty_reservation_output,
          ls_color            TYPE lvc_s_scol.

    LOOP AT gt_reservation_data INTO ls_reservation_data.
      CLEAR: ls_material_text, ls_plant_text, ls_report_output.

      READ TABLE gt_material_text INTO ls_material_text
        WITH KEY matnr = ls_reservation_data-matnr
        BINARY SEARCH.

      READ TABLE gt_plant_text INTO ls_plant_text
        WITH KEY werks = ls_reservation_data-werks
        BINARY SEARCH.

      ls_report_output-reservation = ls_reservation_data-rsnum.

      IF ls_plant_text-name1 IS INITIAL.
        ls_report_output-plant = ls_reservation_data-werks.
      ELSE.
        ls_report_output-plant = |{ ls_reservation_data-werks } - { ls_plant_text-name1 }|.
      ENDIF.

      ls_report_output-material      = ls_reservation_data-matnr.
      ls_report_output-mat_desc      = ls_material_text-maktx.
      ls_report_output-item_no       = ls_reservation_data-rspos.
      ls_report_output-order_no      = ls_reservation_data-aufnr.
      ls_report_output-req_type      = ls_reservation_data-bdart.
      ls_report_output-mov_type      = ls_reservation_data-bwart.
      ls_report_output-gl_account    = ls_reservation_data-saknr.
      ls_report_output-sloc          = ls_reservation_data-lgort.
      ls_report_output-batch         = ls_reservation_data-charg.
      ls_report_output-req_date      = lcl_format_helper=>format_date_mdy( ls_reservation_data-bdter ).
      ls_report_output-req_qty       = ls_reservation_data-bdmng.
      ls_report_output-base_unit     = ls_reservation_data-meins.
      ls_report_output-debit_credit  = ls_reservation_data-shkzg.
      ls_report_output-withdraw_qty  = ls_reservation_data-enmng.
      ls_report_output-withdr_value  = ls_reservation_data-enwrt.
      ls_report_output-currency      = ls_reservation_data-waers.
      ls_report_output-qty_une       = ls_reservation_data-erfmg.
      ls_report_output-unit_entry    = ls_reservation_data-erfme.
      ls_report_output-plant_sort    = ls_reservation_data-werks.

      IF ls_reservation_data-bdmng = 0.
        CLEAR ls_color.
        ls_color-fname = 'REQ_QTY'.
        ls_color-color-col = 6.
        ls_color-color-int = 1.
        ls_color-color-inv = 0.
        APPEND ls_color TO ls_report_output-cell_color.
      ENDIF.

      APPEND ls_report_output TO gt_report_output.
    ENDLOOP.

    SORT gt_report_output BY reservation ASCENDING
                             plant_sort ASCENDING
                             material ASCENDING
                             item_no ASCENDING.
  ENDMETHOD.

ENDCLASS.

************************************************************************
* EVENT HANDLER IMPLEMENTATION
************************************************************************
CLASS lcl_reservation_events IMPLEMENTATION.
  METHOD on_link_click.
    READ TABLE lcl_reservation_service=>gt_report_output INTO DATA(ls_report_output) INDEX row.
    IF sy-subrc <> 0.
      RETURN.
    ENDIF.

    IF column = 'MATERIAL' AND p_hili = 'X'.
      SET PARAMETER ID 'MAT' FIELD ls_report_output-material.
      CALL TRANSACTION 'MM03' WITH AUTHORITY-CHECK AND SKIP FIRST SCREEN.
    ENDIF.
  ENDMETHOD.
ENDCLASS.

************************************************************************
* VIEW CLASS IMPLEMENTATION
************************************************************************
CLASS lcl_reservation_view IMPLEMENTATION.

  METHOD display_write.
    DATA: ls_report_output TYPE ty_reservation_output,
          lv_exec_date     TYPE char10,
          lv_exec_time     TYPE char8.

    lv_exec_date = lcl_format_helper=>format_date_mdy( sy-datum ).
    lv_exec_time = lcl_format_helper=>format_time_military( sy-uzeit ).

    WRITE: / text-h01.
    WRITE: / text-h02.
    WRITE: / 'Executed by:', sy-uname.
    WRITE: / 'Executed on:', lv_exec_date, lv_exec_time.
    SKIP.

    FORMAT COLOR COL_HEADING INTENSIFIED ON.
    WRITE: / text-c01, 15 text-c02, 55 text-c03, 75 text-c04, 100 text-c05.
    WRITE: / text-c06, 15 text-c07, 35 text-c08, 55 text-c09, 75 text-c10.
    WRITE: / text-c11, 15 text-c12, 35 text-c13, 55 text-c14, 75 text-c15.
    WRITE: / text-c16, 20 text-c17, 40 text-c18, 55 text-c19, 75 text-c20.
    FORMAT RESET.

    LOOP AT lcl_reservation_service=>gt_report_output INTO ls_report_output.
      WRITE: / ls_report_output-reservation,
               15 ls_report_output-plant,
               55 ls_report_output-material,
               75 ls_report_output-mat_desc,
               100 ls_report_output-item_no.
      WRITE: / ls_report_output-order_no,
               15 ls_report_output-req_type,
               35 ls_report_output-mov_type,
               55 ls_report_output-gl_account,
               75 ls_report_output-sloc.
      WRITE: / ls_report_output-batch,
               15 ls_report_output-req_date,
               35 ls_report_output-req_qty,
               55 ls_report_output-base_unit,
               75 ls_report_output-debit_credit.
      WRITE: / ls_report_output-withdraw_qty,
               20 ls_report_output-withdr_value,
               40 ls_report_output-currency,
               55 ls_report_output-qty_une,
               75 ls_report_output-unit_entry.
      ULINE.
    ENDLOOP.
  ENDMETHOD.

  METHOD display_alv.
    DATA: lo_alv        TYPE REF TO cl_salv_table,
          lo_columns    TYPE REF TO cl_salv_columns_table,
          lo_column     TYPE REF TO cl_salv_column_table,
          lo_functions  TYPE REF TO cl_salv_functions_list,
          lo_display    TYPE REF TO cl_salv_display_settings,
          lo_sorts      TYPE REF TO cl_salv_sorts,
          lo_header     TYPE REF TO cl_salv_form_layout_grid,
          lo_events     TYPE REF TO cl_salv_events_table,
          lo_handler    TYPE REF TO lcl_reservation_events,
          lv_exec_date  TYPE char10,
          lv_exec_time  TYPE char8.

    lv_exec_date = lcl_format_helper=>format_date_mdy( sy-datum ).
    lv_exec_time = lcl_format_helper=>format_time_military( sy-uzeit ).

    TRY.
        cl_salv_table=>factory(
          IMPORTING
            r_salv_table = lo_alv
          CHANGING
            t_table      = lcl_reservation_service=>gt_report_output ).

        lo_columns = lo_alv->get_columns( ).

        TRY.
            lo_columns->set_optimize( ).
          CATCH cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_columns->set_color_column( 'CELL_COLOR' ).
          CATCH cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'RESERVATION' ).
            lo_column->set_short_text(  CONV scrtext_s( text-c01 ) ).
            lo_column->set_medium_text( CONV scrtext_m( text-c01 ) ).
            lo_column->set_long_text(   CONV scrtext_l( text-c01 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'PLANT' ).
            lo_column->set_short_text(  CONV scrtext_s( text-c02 ) ).
            lo_column->set_medium_text( CONV scrtext_m( text-c02 ) ).
            lo_column->set_long_text(   CONV scrtext_l( text-c02 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'MATERIAL' ).
            lo_column->set_short_text(  CONV scrtext_s( text-c03 ) ).
            lo_column->set_medium_text( CONV scrtext_m( text-c03 ) ).
            lo_column->set_long_text(   CONV scrtext_l( text-c03 ) ).
            IF p_hili = 'X'.
              lo_column->set_cell_type( if_salv_c_cell_type=>hotspot ).
            ENDIF.
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'MAT_DESC' ).
            lo_column->set_short_text(  CONV scrtext_s( text-c04 ) ).
            lo_column->set_medium_text( CONV scrtext_m( text-c04 ) ).
            lo_column->set_long_text(   CONV scrtext_l( text-c04 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'ITEM_NO' ).
            lo_column->set_short_text(  CONV scrtext_s( text-c05 ) ).
            lo_column->set_medium_text( CONV scrtext_m( text-c05 ) ).
            lo_column->set_long_text(   CONV scrtext_l( text-c05 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
            lo_column ?= lo_columns->get_column( 'ORDER_NO' ).
            lo_column->set_short_text(  CONV scrtext_s( text-c06 ) ).
            lo_column->set_medium_text( CONV scrtext_m( text-c06 ) ).
            lo_column->set_long_text(   CONV scrtext_l( text-c06 ) ).
          CATCH cx_salv_not_found cx_salv_data_error.
        ENDTRY.

        TRY.
