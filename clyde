REPORT zmm_reservation_report.

INCLUDE zmm_reservation_report_top.
INCLUDE zmm_reservation_report_sel.
INCLUDE zmm_reservation_report_f01.

AT SELECTION-SCREEN.

  lcl_reservation_service=>validate_reservation_input(
    it_reservation = so_reservation[] ).

  lcl_reservation_service=>validate_material_input(
    it_material = so_material[] ).

  lcl_reservation_service=>validate_plant_input(
    iv_plant = p_plant ).

START-OF-SELECTION.

  CREATE OBJECT go_reservation_service.

  go_reservation_service->get_data(
    it_reservation = so_reservation[]
    it_material    = so_material[]
    iv_plant       = p_plant
    iv_highlight   = COND abap_bool(
                       WHEN p_hili = 'X'
                       THEN abap_true
                       ELSE abap_false ) ).

  CREATE OBJECT go_reservation_view.

  IF p_writ = 'X'.
    go_reservation_view->display_write( ).
  ELSE.
    go_reservation_view->display_alv( ).
  ENDIF.



