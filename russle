    ENDLOOP.
  ENDMETHOD.

METHOD display_salv.

  DATA: lo_alv      TYPE REF TO cl_salv_table,
        lo_columns  TYPE REF TO cl_salv_columns_table,
        lo_column   TYPE REF TO cl_salv_column_table,
        lo_sorts    TYPE REF TO cl_salv_sorts,
        lo_events   TYPE REF TO cl_salv_events_table,
        lo_handler  TYPE REF TO lcl_events,
        lo_display  TYPE REF TO cl_salv_display_settings,
        lo_funcs    TYPE REF TO cl_salv_functions_list,
        lo_layout   TYPE REF TO cl_salv_form_layout_grid,
        lo_text     TYPE REF TO cl_salv_form_text,
        ls_color    TYPE lvc_s_colo.

  TRY.
      cl_salv_table=>factory(
        IMPORTING
          r_salv_table = lo_alv
        CHANGING
          t_table      = it_final ).

      lo_display = lo_alv->get_display_settings( ).
      lo_display->set_list_header( CONV lvc_title( text-h01 ) ).
      lo_display->set_striped_pattern( abap_true ).

      lo_funcs = lo_alv->get_functions( ).
      lo_funcs->set_all( abap_true ).

      lo_columns = lo_alv->get_columns( ).
      lo_columns->set_optimize( abap_true ).

      TRY.
          lo_column ?= lo_columns->get_column( 'MATERIAL' ).
          lo_column->set_short_text(  CONV scrtext_s( text-c01 ) ).
          lo_column->set_medium_text( CONV scrtext_m( text-c01 ) ).
          lo_column->set_long_text(   CONV scrtext_l( text-c01 ) ).
          IF p_hot = abap_true.
            lo_column->set_cell_type( if_salv_c_cell_type=>hotspot ).
          ENDIF.
          CLEAR ls_color.
          ls_color-col = 5.
          ls_color-int = 0.
          ls_color-inv = 0.
          lo_column->set_color( ls_color ).
        CATCH cx_salv_not_found cx_salv_data_error.
