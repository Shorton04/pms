CLASS lcl_util IMPLEMENTATION.
  METHOD alpha_input_matnr.
    rv_matnr = iv_matnr.
    CALL FUNCTION 'CONVERSION_EXIT_ALPHA_INPUT'
      EXPORTING
        input  = rv_matnr
      IMPORTING
        output = rv_matnr.
  ENDMETHOD.

  METHOD format_date_mdy.
    IF iv_date IS INITIAL.
      CLEAR rv_text.
      RETURN.
    ENDIF.

    rv_text = |{ iv_date+4(2) }/{ iv_date+6(2) }/{ iv_date+0(4) }|.
  ENDMETHOD.
ENDCLASS.

CLASS lcl_model IMPLEMENTATION.
  METHOD validate_material.
    DATA: ls_raw      TYPE rseloption,
          lv_matnr    TYPE mara-matnr,
          lv_dummy    TYPE mara-matnr.

    LOOP AT it_matnr_raw INTO ls_raw WHERE low IS NOT INITIAL.
      lv_matnr = lcl_util=>alpha_input_matnr( CONV mara-matnr( ls_raw-low ) ).

      SELECT SINGLE matnr
        INTO @lv_dummy
        FROM mara
        WHERE matnr = @lv_matnr.

      IF sy-subrc <> 0.
        MESSAGE text-e01 TYPE 'E'.
      ENDIF.
    ENDLOOP.
  ENDMETHOD.

  METHOD validate_created_on.
    DATA ls_raw TYPE rseloption.

    LOOP AT it_ersda_raw INTO ls_raw.
      IF ls_raw-low IS NOT INITIAL AND CONV sy-datum( ls_raw-low ) > sy-datum.
        MESSAGE text-e02 TYPE 'E'.
      ENDIF.

      IF ls_raw-high IS NOT INITIAL AND CONV sy-datum( ls_raw-high ) > sy-datum.
        MESSAGE text-e02 TYPE 'E'.
      ENDIF.
    ENDLOOP.
  ENDMETHOD.

  METHOD validate_plant.
    DATA lv_dummy TYPE t001w-werks.

    IF iv_werks IS INITIAL.
      RETURN.
    ENDIF.

    SELECT SINGLE werks
      INTO @lv_dummy
      FROM t001w
      WHERE werks = @iv_werks.

    IF sy-subrc <> 0.
      MESSAGE text-e03 TYPE 'E'.
    ENDIF.
  ENDMETHOD.

  METHOD get_data.
    DATA: lt_matnr_rng TYPE RANGE OF mara-matnr,
          lt_ersda_rng TYPE RANGE OF mcha-ersda,
          ls_raw       TYPE rseloption,
          ls_matnr_rng LIKE LINE OF lt_matnr_rng,
          ls_ersda_rng LIKE LINE OF lt_ersda_rng,
          lt_base      TYPE STANDARD TABLE OF ty_base,
          ls_base      TYPE ty_base,
          lt_makt      TYPE STANDARD TABLE OF ty_makt,
          ls_makt      TYPE ty_makt,
          lt_t001w     TYPE STANDARD TABLE OF ty_t001w,
          ls_t001w     TYPE ty_t001w,
          ls_final     TYPE ty_final,
          lv_matnr_out TYPE mara-matnr.

    CLEAR: et_final, gt_final.

    LOOP AT it_matnr_raw INTO ls_raw.
      CLEAR ls_matnr_rng.
      ls_matnr_rng-sign   = ls_raw-sign.
      ls_matnr_rng-option = ls_raw-option.
      ls_matnr_rng-low    = lcl_util=>alpha_input_matnr( CONV mara-matnr( ls_raw-low ) ).
      ls_matnr_rng-high   = lcl_util=>alpha_input_matnr( CONV mara-matnr( ls_raw-high ) ).
      APPEND ls_matnr_rng TO lt_matnr_rng.
    ENDLOOP.

    LOOP AT it_ersda_raw INTO ls_raw.
      CLEAR ls_ersda_rng.
      ls_ersda_rng-sign   = ls_raw-sign.
      ls_ersda_rng-option = ls_raw-option.
      ls_ersda_rng-low    = CONV mcha-ersda( ls_raw-low ).
      ls_ersda_rng-high   = CONV mcha-ersda( ls_raw-high ).
      APPEND ls_ersda_rng TO lt_ersda_rng.
    ENDLOOP.

    SELECT a~matnr,
           a~mtart,
           a~matkl,
           a~mbrsh,
           b~werks,
           b~charg,
           b~ersda,
           b~ernam,
           b~laeda,
           b~aenam,
           b~bwtar,
           b~brgew,
           b~ntgew,
           b~gewei,
           b~volum,
           b~voleh,
           b~lifnr,
           b~lwedt,
           b~herkl
      FROM mara AS a
      INNER JOIN mcha AS b
        ON b~matnr = a~matnr
      INTO TABLE @lt_base
      WHERE a~matnr IN @lt_matnr_rng
        AND ( @iv_werks IS INITIAL OR b~werks = @iv_werks )
        AND ( @lt_ersda_rng IS INITIAL OR b~ersda IN @lt_ersda_rng ).

    IF lt_base IS INITIAL.
      RETURN.
    ENDIF.

    SORT lt_base BY matnr werks charg.
    DELETE ADJACENT DUPLICATES FROM lt_base COMPARING matnr werks charg.

    SELECT matnr maktx
      FROM makt
      INTO TABLE @lt_makt
      FOR ALL ENTRIES IN @lt_base
      WHERE matnr = @lt_base-matnr
        AND spras = @sy-langu.

    SELECT werks name1
      FROM t001w
      INTO TABLE @lt_t001w
      FOR ALL ENTRIES IN @lt_base
      WHERE werks = @lt_base-werks.

    SORT lt_makt BY matnr.
    SORT lt_t001w BY werks.

    LOOP AT lt_base INTO ls_base.
      CLEAR: ls_final, ls_makt, ls_t001w, lv_matnr_out.

      READ TABLE lt_makt INTO ls_makt
        WITH KEY matnr = ls_base-matnr
        BINARY SEARCH.

      READ TABLE lt_t001w INTO ls_t001w
        WITH KEY werks = ls_base-werks
        BINARY SEARCH.

      CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
        EXPORTING
          input  = ls_base-matnr
        IMPORTING
          output = lv_matnr_out.

      CONCATENATE lv_matnr_out ls_makt-maktx
        INTO ls_final-material
        SEPARATED BY ' - '.

      ls_final-plant           = ls_base-werks.
      ls_final-plant_name      = ls_t001w-name1.
      ls_final-batch           = ls_base-charg.
      ls_final-created_on      = lcl_util=>format_date_mdy( ls_base-ersda ).
      ls_final-created_by      = ls_base-ernam.
      ls_final-changed_on      = lcl_util=>format_date_mdy( ls_base-laeda ).
      ls_final-changed_by      = ls_base-aenam.
      ls_final-material_type   = ls_base-mtart.
      ls_final-valuation_type  = ls_base-bwtar.
      ls_final-material_group  = ls_base-matkl.
      ls_final-industry_sector = ls_base-mbrsh.
      ls_final-gross_weight    = ls_base-brgew.
      ls_final-net_weight      = ls_base-ntgew.
      ls_final-unit_of_weight  = ls_base-gewei.
      ls_final-volume          = ls_base-volum.
      ls_final-volume_unit     = ls_base-voleh.
      ls_final-supplier        = ls_base-lifnr.
      ls_final-goods_receipt   = lcl_util=>format_date_mdy( ls_base-lwedt ).
      ls_final-country         = ls_base-herkl.

      ls_final-matnr_raw       = ls_base-matnr.
      ls_final-werks_raw       = ls_base-werks.
      ls_final-charg_raw       = ls_base-charg.
      ls_final-ersda_raw       = ls_base-ersda.

      APPEND ls_final TO et_final.
    ENDLOOP.

    SORT et_final BY matnr_raw ASCENDING
                     werks_raw ASCENDING
                     charg_raw ASCENDING
                     ersda_raw DESCENDING.

    gt_final = et_final.
  ENDMETHOD.
ENDCLASS.

CLASS lcl_events IMPLEMENTATION.
  METHOD on_link_click.
    DATA ls_final TYPE ty_final.

    CHECK p_hot = abap_true.
    CHECK column = 'MATERIAL'.

    READ TABLE lcl_model=>gt_final INTO ls_final INDEX row.
    CHECK sy-subrc = 0.

    SET PARAMETER ID 'MAT' FIELD ls_final-matnr_raw.
    CALL TRANSACTION 'MM03' WITH AUTHORITY-CHECK AND SKIP FIRST SCREEN.
  ENDMETHOD.
ENDCLASS.

