          lo_column->set_long_text(   CONV scrtext_l( text-c19 ) ).
        CATCH cx_salv_not_found cx_salv_data_error.
      ENDTRY.

      TRY.
          lo_column ?= lo_columns->get_column( 'COUNTRY' ).
          lo_column->set_short_text(  CONV scrtext_s( text-c20 ) ).
          lo_column->set_medium_text( CONV scrtext_m( text-c20 ) ).
          lo_column->set_long_text(   CONV scrtext_l( text-c20 ) ).
        CATCH cx_salv_not_found cx_salv_data_error.
      ENDTRY.

      " Hide technical columns
      TRY.
          lo_column ?= lo_columns->get_column( 'MATNR_RAW' ).
          lo_column->set_technical( abap_true ).
        CATCH cx_salv_not_found.
      ENDTRY.

      TRY.
          lo_column ?= lo_columns->get_column( 'WERKS_RAW' ).
          lo_column->set_technical( abap_true ).
        CATCH cx_salv_not_found.
      ENDTRY.

      TRY.
          lo_column ?= lo_columns->get_column( 'CHARG_RAW' ).
          lo_column->set_technical( abap_true ).
        CATCH cx_salv_not_found.
      ENDTRY.

      TRY.
          lo_column ?= lo_columns->get_column( 'ERSDA_RAW' ).
          lo_column->set_technical( abap_true ).
        CATCH cx_salv_not_found.
      ENDTRY.

      lo_sorts = lo_alv->get_sorts( ).
      lo_sorts->add_sort(
        columnname = 'MATERIAL'
        sequence   = if_salv_c_sort=>sort_up ).
      lo_sorts->add_sort(
        columnname = 'PLANT'
        sequence   = if_salv_c_sort=>sort_up ).
      lo_sorts->add_sort(
        columnname = 'BATCH'
        sequence   = if_salv_c_sort=>sort_up ).
      lo_sorts->add_sort(
        columnname = 'ERSDA_RAW'
        sequence   = if_salv_c_sort=>sort_down ).

      CREATE OBJECT lo_layout.
      lo_text = lo_layout->create_text(
                  row    = 1
                  column = 1
                  text   = CONV string( text-h02 ) ).
      lo_text = lo_layout->create_text(
                  row    = 2
                  column = 1
                  text   = |Executed by: { sy-uname }| ).
      lo_text = lo_layout->create_text(
                  row    = 3
                  column = 1
                  text   = |Executed on: { lcl_util=>format_date_mdy( sy-datum ) } - { sy-uzeit }| ).

      lo_alv->set_top_of_list( lo_layout ).

      lo_events = lo_alv->get_event( ).
      CREATE OBJECT lo_handler.
      SET HANDLER lo_handler->on_link_click FOR lo_events.

      lo_alv->display( ).

    CATCH cx_salv_msg INTO DATA(lx_salv).
      MESSAGE lx_salv->get_text( ) TYPE 'S' DISPLAY LIKE 'E'.
  ENDTRY.

ENDMETHOD.

FORM build_rseloption_tables.
  DATA ls_raw TYPE rseloption.

  CLEAR: gt_matnr_raw, gt_ersda_raw.

  LOOP AT s_matnr ASSIGNING FIELD-SYMBOL(<fs_matnr>).
    CLEAR ls_raw.
    ls_raw-sign   = <fs_matnr>-sign.
    ls_raw-option = <fs_matnr>-option.
    ls_raw-low    = <fs_matnr>-low.
    ls_raw-high   = <fs_matnr>-high.
    APPEND ls_raw TO gt_matnr_raw.
  ENDLOOP.

  LOOP AT s_ersda ASSIGNING FIELD-SYMBOL(<fs_ersda>).
    CLEAR ls_raw.
    ls_raw-sign   = <fs_ersda>-sign.
    ls_raw-option = <fs_ersda>-option.
    ls_raw-low    = <fs_ersda>-low.
    ls_raw-high   = <fs_ersda>-high.
    APPEND ls_raw TO gt_ersda_raw.
  ENDLOOP.
ENDFORM.

AT SELECTION-SCREEN.
  PERFORM build_rseloption_tables.
  lcl_model=>validate_material( gt_matnr_raw ).
  lcl_model=>validate_created_on( gt_ersda_raw ).
  lcl_model=>validate_plant( p_werks ).

START-OF-SELECTION.
  DATA: lo_model TYPE REF TO lcl_model,
        lo_view  TYPE REF TO lcl_view,
        lt_final TYPE tt_final.

  PERFORM build_rseloption_tables.

  CREATE OBJECT lo_model.
  lo_model->get_data(
    EXPORTING
      it_matnr_raw = gt_matnr_raw
      it_ersda_raw = gt_ersda_raw
      iv_werks     = p_werks
    IMPORTING
      et_final     = lt_final ).

  IF lt_final IS INITIAL.
    MESSAGE text-e04 TYPE 'S' DISPLAY LIKE 'E'.
    RETURN.
  ENDIF.

  CREATE OBJECT lo_view.

  IF p_wrt = abap_true.
    lo_view->display_write( lt_final ).
  ELSE.
    lo_view->display_salv( lt_final ).
  ENDIF.




