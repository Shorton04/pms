CLASS lcl_util DEFINITION FINAL.
  PUBLIC SECTION.
    CLASS-METHODS:
      alpha_input_matnr
        IMPORTING iv_matnr TYPE mara-matnr
        RETURNING VALUE(rv_matnr) TYPE mara-matnr,
      format_date_mdy
        IMPORTING iv_date TYPE sy-datum
        RETURNING VALUE(rv_text) TYPE char10.
ENDCLASS.

CLASS lcl_model DEFINITION FINAL.
  PUBLIC SECTION.
    CLASS-DATA gt_final TYPE tt_final.

    CLASS-METHODS:
      validate_material
        IMPORTING it_matnr_raw TYPE STANDARD TABLE OF rseloption,
      validate_created_on
        IMPORTING it_ersda_raw TYPE STANDARD TABLE OF rseloption,
      validate_plant
        IMPORTING iv_werks TYPE mcha-werks.

    METHODS:
      get_data
        IMPORTING
